<?xml version="1.0" encoding="UTF-8"?>
<!--
    Test file for multiple subordinate substance administrations.
    This tests the EAV transformation for:
    1. Medication with MULTIPLE subordinate administrations (should create separate facts)
    2. Medication WITHOUT subordinate (edge case - single fact with medication info only)
    3. Multiple approachSiteCode elements (should be numbered: approachSiteCode:1, approachSiteCode:2)
-->
<ClinicalDocument xmlns="urn:hl7-org:v3" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <realmCode code="DE"/>
    <typeId root="2.16.840.1.113883.1.3" extension="POCD_HD000040"/>
    <templateId root="1.2.276.0.76.3.1.195.10.92"/>
    <id root="1.2.276.0.76.4.17.9814184919" extension="test-multi-subordinate"/>
    <code code="68552-9" codeSystem="2.16.840.1.113883.6.1"/>
    <effectiveTime value="20240117120000"/>
    <confidentialityCode code="N" codeSystem="2.16.840.1.113883.5.25"/>
    <languageCode code="de-DE"/>
    <recordTarget>
        <patientRole>
            <id root="1.2.276.0.76.4.8" extension="TEST-MULTI-SUB-001"/>
            <patient>
                <administrativeGenderCode code="M" codeSystem="2.16.840.1.113883.5.1"/>
                <birthTime value="19800515"/>
            </patient>
        </patientRole>
    </recordTarget>
    <author>
        <time value="20240117120000"/>
        <assignedAuthor>
            <id root="1.2.276.0.76.4.17.9814184919" extension="author-001"/>
        </assignedAuthor>
    </author>
    <custodian>
        <assignedCustodian>
            <representedCustodianOrganization>
                <id root="1.2.276.0.76.4.17.9814184919" extension="org-001"/>
            </representedCustodianOrganization>
        </assignedCustodian>
    </custodian>
    <componentOf>
        <encompassingEncounter>
            <id root="1.2.276.0.76.4.17.9814184919" extension="encounter-multi-sub-test"/>
            <effectiveTime>
                <low value="20240117100000"/>
                <high value="20240117180000"/>
            </effectiveTime>
            <dischargeDispositionCode code="4"/>
        </encompassingEncounter>
    </componentOf>
    <component>
        <structuredBody>
            <component>
                <section>
                    <templateId root="1.2.276.0.76.3.1.195.10.64"/>
                    <code code="29549-3" codeSystem="2.16.840.1.113883.6.1"/>
                    <title>Medikation - Test Multiple Subordinates</title>
                    <text>
                        <list>
                            <item ID="med-multi">Paracetamol with 3 administrations (morning 500mg, noon 1000mg, evening 500mg)</item>
                            <item ID="med-single">Aspirin standalone medication without subordinate</item>
                            <item ID="med-sites">Lidocain with multiple approach sites</item>
                        </list>
                    </text>

                    <!-- Test Case 1: Medication with MULTIPLE subordinate administrations -->
                    <entry typeCode="COMP">
                        <substanceAdministration classCode="SBADM" moodCode="EVN">
                            <templateId root="1.2.276.0.76.3.1.195.10.67"/>
                            <id root="1.2.276.0.76.4.17.9814184919" extension="med-multi-001"/>
                            <code code="DRUG" codeSystem="2.16.840.1.113883.5.4"/>
                            <text>
                                <reference value="#med-multi"/>
                            </text>
                            <statusCode code="active"/>
                            <routeCode code="PO" codeSystem="2.16.840.1.113883.5.112" displayName="Oral"/>
                            <consumable typeCode="CSM">
                                <manufacturedProduct classCode="MANU">
                                    <templateId root="2.16.840.1.113883.10.21.4.10"/>
                                    <manufacturedMaterial classCode="MMAT">
                                        <code code="N02BE01" codeSystem="2.16.840.1.113883.6.73" displayName="Paracetamol"/>
                                    </manufacturedMaterial>
                                </manufacturedProduct>
                            </consumable>
                            <!-- First subordinate: Morning dose 500mg -->
                            <entryRelationship typeCode="COMP">
                                <substanceAdministration classCode="SBADM" moodCode="EVN">
                                    <templateId root="2.16.840.1.113883.10.21.4.6"/>
                                    <statusCode code="completed"/>
                                    <effectiveTime value="20240117080000"/>
                                    <doseQuantity value="500" unit="mg"/>
                                    <consumable>
                                        <manufacturedProduct>
                                            <manufacturedMaterial nullFlavor="NA"/>
                                        </manufacturedProduct>
                                    </consumable>
                                </substanceAdministration>
                            </entryRelationship>
                            <!-- Second subordinate: Noon dose 1000mg -->
                            <entryRelationship typeCode="COMP">
                                <substanceAdministration classCode="SBADM" moodCode="EVN">
                                    <templateId root="2.16.840.1.113883.10.21.4.6"/>
                                    <statusCode code="completed"/>
                                    <effectiveTime value="20240117120000"/>
                                    <doseQuantity value="1000" unit="mg"/>
                                    <rateQuantity value="100" unit="ml/h"/>
                                    <consumable>
                                        <manufacturedProduct>
                                            <manufacturedMaterial nullFlavor="NA"/>
                                        </manufacturedProduct>
                                    </consumable>
                                </substanceAdministration>
                            </entryRelationship>
                            <!-- Third subordinate: Evening dose 500mg -->
                            <entryRelationship typeCode="COMP">
                                <substanceAdministration classCode="SBADM" moodCode="EVN">
                                    <templateId root="2.16.840.1.113883.10.21.4.6"/>
                                    <statusCode code="active"/>
                                    <effectiveTime value="20240117200000"/>
                                    <doseQuantity value="500" unit="mg"/>
                                    <consumable>
                                        <manufacturedProduct>
                                            <manufacturedMaterial nullFlavor="NA"/>
                                        </manufacturedProduct>
                                    </consumable>
                                </substanceAdministration>
                            </entryRelationship>
                        </substanceAdministration>
                    </entry>

                    <!-- Test Case 2: Medication WITHOUT subordinate (edge case) -->
                    <entry typeCode="COMP">
                        <substanceAdministration classCode="SBADM" moodCode="INT">
                            <templateId root="1.2.276.0.76.3.1.195.10.67"/>
                            <id root="1.2.276.0.76.4.17.9814184919" extension="med-single-001"/>
                            <code code="DRUG" codeSystem="2.16.840.1.113883.5.4"/>
                            <text>
                                <reference value="#med-single"/>
                            </text>
                            <statusCode code="active"/>
                            <routeCode code="PO" codeSystem="2.16.840.1.113883.5.112" displayName="Oral"/>
                            <consumable typeCode="CSM">
                                <manufacturedProduct classCode="MANU">
                                    <templateId root="2.16.840.1.113883.10.21.4.10"/>
                                    <manufacturedMaterial classCode="MMAT">
                                        <code code="N02BA01" codeSystem="2.16.840.1.113883.6.73" displayName="Acetylsalicylic acid"/>
                                    </manufacturedMaterial>
                                </manufacturedProduct>
                            </consumable>
                            <!-- No subordinate substance administration -->
                        </substanceAdministration>
                    </entry>

                    <!-- Test Case 3: Medication with MULTIPLE approachSiteCode elements -->
                    <entry typeCode="COMP">
                        <substanceAdministration classCode="SBADM" moodCode="EVN">
                            <templateId root="1.2.276.0.76.3.1.195.10.67"/>
                            <id root="1.2.276.0.76.4.17.9814184919" extension="med-sites-001"/>
                            <code code="DRUG" codeSystem="2.16.840.1.113883.5.4"/>
                            <text>
                                <reference value="#med-sites"/>
                            </text>
                            <statusCode code="completed"/>
                            <routeCode code="ISINJ" codeSystem="2.16.840.1.113883.5.112" displayName="Injection, intraspinal"/>
                            <!-- Multiple approach site codes - should be numbered -->
                            <approachSiteCode code="LA" codeSystem="2.16.840.1.113883.5.1052" displayName="Left Arm"/>
                            <approachSiteCode code="RA" codeSystem="2.16.840.1.113883.5.1052" displayName="Right Arm"/>
                            <approachSiteCode code="LF" codeSystem="2.16.840.1.113883.5.1052" displayName="Left Foot"/>
                            <consumable typeCode="CSM">
                                <manufacturedProduct classCode="MANU">
                                    <templateId root="2.16.840.1.113883.10.21.4.10"/>
                                    <manufacturedMaterial classCode="MMAT">
                                        <code code="N01BB02" codeSystem="2.16.840.1.113883.6.73" displayName="Lidocaine"/>
                                    </manufacturedMaterial>
                                </manufacturedProduct>
                            </consumable>
                            <!-- Single subordinate for this test -->
                            <entryRelationship typeCode="COMP">
                                <substanceAdministration classCode="SBADM" moodCode="EVN">
                                    <templateId root="2.16.840.1.113883.10.21.4.6"/>
                                    <statusCode code="completed"/>
                                    <effectiveTime value="20240117143000"/>
                                    <doseQuantity value="20" unit="ml"/>
                                    <consumable>
                                        <manufacturedProduct>
                                            <manufacturedMaterial nullFlavor="NA"/>
                                        </manufacturedProduct>
                                    </consumable>
                                </substanceAdministration>
                            </entryRelationship>
                        </substanceAdministration>
                    </entry>

                </section>
            </component>
        </structuredBody>
    </component>
</ClinicalDocument>
